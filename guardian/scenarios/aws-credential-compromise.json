{
  "metadata": {
    "name": "AWS Credential Compromise & Lateral Movement",
    "description": "Simulates an AWS attack: stolen IAM credentials used to create backdoor access keys, disable CloudTrail, exfiltrate S3 data, and terminate instances. Based on EMERALDWHALE and Crimson Collective TTPs.",
    "author": "Guardian Security Team",
    "version": "1.0",
    "tags": ["cloud", "aws", "iam", "credential-theft", "lateral-movement"],
    "circuit_breaker_enabled": true,
    "circuit_breaker_max_per_minute": 5,
    "circuit_breaker_max_per_hour": 20,
    "register_actors": [
      {
        "name": "aws-123456789012-admin-user",
        "type": "human",
        "max_privilege_level": "admin",
        "status": "active"
      },
      {
        "name": "aws-role-deploy-pipeline",
        "type": "automation",
        "max_privilege_level": "elevated",
        "status": "active"
      }
    ]
  },
  "events": [
