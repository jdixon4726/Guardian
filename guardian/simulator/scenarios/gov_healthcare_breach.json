{
  "metadata": {
    "name": "Government Healthcare Breach \u2014 VA Hospital Device Wipe + PHI Exfiltration",
    "description": "Simulates a coordinated attack on a VA hospital network: attacker compromises Entra ID admin, creates rogue service account, exfiltrates PHI from clinical databases, wipes Intune-managed clinical workstations, and disables endpoint protection on imaging systems. Tests Guardian's gov healthcare template with HIPAA + NIST 800-53 + FedRAMP controls.",
    "author": "Guardian Security Team",
    "version": "1.0",
    "tags": ["government", "healthcare", "va-hospital", "hipaa", "nist-800-53", "fedramp", "phi", "wiper", "intune"],
    "circuit_breaker_enabled": true,
    "circuit_breaker_max_per_minute": 2,
    "circuit_breaker_max_per_hour": 6,
    "register_actors": [
      {"name": "va-itops-admin@va.gov", "type": "human", "max_privilege_level": "admin", "status": "active"},
      {"name": "va-clinical-imaging-svc", "type": "automation", "max_privilege_level": "standard", "status": "active"},
      {"name": "va-ehrs-sync-bot", "type": "automation", "max_privilege_level": "elevated", "status": "active"}
    ]
  },
  "events": [
    {
