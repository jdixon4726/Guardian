      "timestamp": "2026-03-01T08:00:00Z",
      "adapter": "direct",
      "phase": "baseline",
      "description": "Normal: EHR sync bot reads patient records for clinical dashboard",
      "payload": {
        "actor_name": "va-ehrs-sync-bot",
        "actor_type": "automation",
        "requested_action": "change_configuration",
        "target_system": "va-ehrm-cerner",
        "target_asset": "ehrm/patient-records/sync",
