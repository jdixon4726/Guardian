    {
      "id": "recovery-deploy-01", "timestamp": "2026-03-10T09:00:00Z", "adapter": "aws",
      "phase": "recovery", "description": "Legitimate deploy pipeline runs — unaffected by attacker lockout",
      "payload": {"event_id": "rec-001", "event_time": "2026-03-10T09:00:00Z", "event_source": "rds.amazonaws.com", "event_name": "ModifyDBInstance", "aws_region": "us-east-1", "source_ip": "10.0.1.50", "user_identity_type": "AssumedRole", "user_identity_account_id": "123456789012", "session_issuer_arn": "arn:aws:iam::123456789012:role/deploy-pipeline", "request_parameters": {"dBInstanceIdentifier": "prod-db-primary-restored"}}
    }
  ]
