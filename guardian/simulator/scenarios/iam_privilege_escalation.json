{
  "metadata": {
    "name": "AWS IAM Privilege Escalation — EMERALDWHALE Playbook",
    "description": "Reconstructs the classic AWS credential compromise playbook based on EMERALDWHALE and Rhino Security Labs research. Attacker steals long-term access keys from exposed .git/config, creates backdoor IAM user with AdministratorAccess, disables CloudTrail/GuardDuty, exfiltrates S3 data, creates cross-account persistence via Lambda and IAM role.",
    "author": "Guardian Security Team",
    "version": "1.0",
    "tags": ["aws", "iam", "privilege-escalation", "credential-theft", "emeraldwhale", "cloud"],
    "circuit_breaker_enabled": true,
    "circuit_breaker_max_per_minute": 5,
    "circuit_breaker_max_per_hour": 20,
    "register_actors": [
      {"name": "aws-123456789012-svc-deploy", "type": "automation", "max_privilege_level": "elevated", "status": "active"},
      {"name": "aws-role-deploy-pipeline", "type": "automation", "max_privilege_level": "elevated", "status": "active"},
      {"name": "aws-123456789012-admin-ops", "type": "human", "max_privilege_level": "admin", "status": "active"}
    ]
  },
  "events": [
    {
      "id": "baseline-deploy-01", "timestamp": "2026-03-01T14:00:00Z", "adapter": "aws",
      "phase": "baseline", "description": "Normal deploy pipeline modifies RDS parameter group",
      "payload": {"event_id": "bl-001", "event_time": "2026-03-01T14:00:00Z", "event_source": "rds.amazonaws.com", "event_name": "ModifyDBInstance", "aws_region": "us-east-1", "source_ip": "10.0.1.50", "user_identity_type": "AssumedRole", "user_identity_account_id": "123456789012", "session_issuer_arn": "arn:aws:iam::123456789012:role/deploy-pipeline", "request_parameters": {"dBInstanceIdentifier": "prod-db-primary"}}
    },
    {
      "id": "baseline-admin-01", "timestamp": "2026-03-03T10:00:00Z", "adapter": "aws",
      "phase": "baseline", "description": "Normal admin creates S3 bucket for new feature",
      "payload": {"event_id": "bl-002", "event_time": "2026-03-03T10:00:00Z", "event_source": "s3.amazonaws.com", "event_name": "CreateBucket", "aws_region": "us-east-1", "source_ip": "10.0.2.100", "user_identity_type": "IAMUser", "user_identity_username": "admin-ops", "user_identity_account_id": "123456789012", "request_parameters": {"bucketName": "feature-analytics-staging"}}
    },
    {
      "id": "attack-validate-creds", "timestamp": "2026-03-10T01:00:00Z", "adapter": "aws",
      "phase": "reconnaissance", "description": "Attacker validates stolen access key via sts:GetCallerIdentity",
      "payload": {"event_id": "atk-001", "event_time": "2026-03-10T01:00:00Z", "event_source": "sts.amazonaws.com", "event_name": "GetCallerIdentity", "aws_region": "us-east-1", "source_ip": "185.220.101.42", "user_identity_type": "IAMUser", "user_identity_username": "svc-deploy", "user_identity_account_id": "123456789012", "user_identity_arn": "arn:aws:iam::123456789012:user/svc-deploy"}
    },
    {
      "id": "attack-enum-iam", "timestamp": "2026-03-10T01:15:00Z", "adapter": "aws",
      "phase": "reconnaissance", "description": "Attacker enumerates all IAM policies for privilege escalation paths",
      "payload": {"event_id": "atk-002", "event_time": "2026-03-10T01:15:00Z", "event_source": "iam.amazonaws.com", "event_name": "GetAccountAuthorizationDetails", "aws_region": "us-east-1", "source_ip": "185.220.101.42", "user_identity_type": "IAMUser", "user_identity_username": "svc-deploy", "user_identity_account_id": "123456789012"}
    },
    {
      "id": "attack-create-backdoor-user", "timestamp": "2026-03-10T02:00:00Z", "adapter": "aws",
