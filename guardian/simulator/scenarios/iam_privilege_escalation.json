      "expect_risk_min": 0.5
    },
    {
      "id": "attack-s3-exfil", "timestamp": "2026-03-10T04:00:00Z", "adapter": "aws",
      "phase": "exfiltration", "description": "Attacker exfiltrates production S3 data lake — customer PII",
      "payload": {"event_id": "atk-009", "event_time": "2026-03-10T04:00:00Z", "event_source": "s3.amazonaws.com", "event_name": "GetObject", "aws_region": "us-east-1", "source_ip": "185.220.101.42", "user_identity_type": "IAMUser", "user_identity_username": "svc-deploy", "user_identity_account_id": "123456789012", "request_parameters": {"bucketName": "prod-customer-data-lake", "key": "customers/pii/full-export.csv.gz"}}
    },
    {
      "id": "attack-delete-bucket", "timestamp": "2026-03-10T05:00:00Z", "adapter": "aws",
      "phase": "destruction", "description": "Attacker deletes production S3 bucket after exfiltration",
      "payload": {"event_id": "atk-010", "event_time": "2026-03-10T05:00:00Z", "event_source": "s3.amazonaws.com", "event_name": "DeleteBucket", "aws_region": "us-east-1", "source_ip": "185.220.101.42", "user_identity_type": "IAMUser", "user_identity_username": "svc-deploy", "user_identity_account_id": "123456789012", "request_parameters": {"bucketName": "prod-customer-data-lake"}},
      "expect_risk_min": 0.5
    },
    {
      "id": "attack-terminate-ec2", "timestamp": "2026-03-10T05:05:00Z", "adapter": "aws",
