      "payload": {"event_id": "atk-003", "event_time": "2026-03-10T02:00:00Z", "event_source": "iam.amazonaws.com", "event_name": "CreateUser", "aws_region": "us-east-1", "source_ip": "185.220.101.42", "user_identity_type": "IAMUser", "user_identity_username": "svc-deploy", "user_identity_account_id": "123456789012", "request_parameters": {"userName": "support-svc-temp"}},
      "expect_risk_min": 0.4
    },
    {
      "id": "attack-create-login-profile", "timestamp": "2026-03-10T02:05:00Z", "adapter": "aws",
