      "payload": {"event_id": "atk-014", "event_time": "2026-03-10T05:30:00Z", "event_source": "iam.amazonaws.com", "event_name": "CreateRole", "aws_region": "us-east-1", "source_ip": "185.220.101.42", "user_identity_type": "IAMUser", "user_identity_username": "svc-deploy", "user_identity_account_id": "123456789012", "request_parameters": {"roleName": "OrganizationSyncRole"}},
