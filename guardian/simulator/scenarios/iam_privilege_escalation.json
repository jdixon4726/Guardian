      "payload": {"event_id": "atk-007", "event_time": "2026-03-10T03:00:00Z", "event_source": "cloudtrail.amazonaws.com", "event_name": "StopLogging", "aws_region": "us-east-1", "source_ip": "185.220.101.42", "user_identity_type": "IAMUser", "user_identity_username": "svc-deploy", "user_identity_account_id": "123456789012", "request_parameters": {"name": "management-trail"}},
      "expect_risk_min": 0.5
